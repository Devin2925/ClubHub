<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.clubhub.api</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/devinmcnair/Desktop/ClubHub/backend/clubhub_api.sh</string>
