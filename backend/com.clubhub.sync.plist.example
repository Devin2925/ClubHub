<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.clubhub.sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>/Users/devinmcnair/Desktop/ClubHub/backend/clubhub_sync.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/devinmcnair/Desktop/ClubHub/backend</string>

  <key>RunAtLoad</key>
  <true/>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key>
    <integer>1</integer>
    <key>Hour</key>
    <integer>4</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>/Users/devinmcnair/Desktop/ClubHub/backend/logs/launchd.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/devinmcnair/Desktop/ClubHub/backend/logs/launchd.err.log</string>
</dict>
</plist>
